# Copy to .env and fill in values. Do not commit .env.
# PORT=4003
# NODE_ENV=development
# LOG_LEVEL=info
# MONGODB_URI=
# REDIS_URL=
# OPENAI_API_KEY=
# Optional: public URL for CORS / docs (e.g. https://api.bleujs.org or https://bleujs.org)
# PUBLIC_URL=

# ML / XGBoost (optional — for Python prediction API and scripts)
# MODEL_DIR=./models
# MODEL_PATH=./models/xgboost_model_latest.pkl
# Hugging Face: token for gated repos and uploads; repo for download script
# HF_TOKEN=hf_xxxx
# HF_REPO_ID=pejmantheory/bleu-xgboost-classifier

# (Add any other vars your app reads from process.env)
