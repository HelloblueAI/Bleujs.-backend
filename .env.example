# Copy to .env and fill in values. Do not commit .env.
# PORT=4003
# HOST=127.0.0.1
# NODE_ENV=development
# LOG_LEVEL=info
# LOG_MAX_BYTES=5242880
# LOG_MAX_FILES=5
# Optional: comma-separated API keys required for /api/* routes
# BLEU_API_KEYS=
# Request/input safety limits
# MAX_REQUEST_BODY_BYTES=1048576
# MAX_JSON_BODY_BYTES=1048576
# MAX_EMBED_INPUTS=128
# MAX_EMBED_TEXT_CHARS=8192
# MONGODB_URI=
# MONGO_INITDB_ROOT_USERNAME=admin
# MONGO_INITDB_ROOT_PASSWORD=
# REDIS_URL=
# OPENAI_API_KEY=
# Optional: public URL for CORS / docs (e.g. https://api.bleujs.org or https://bleujs.org)
# PUBLIC_URL=

# ML / XGBoost (optional — for Python prediction API and scripts)
# AI_PORT=8000
# MODEL_DIR=./models
# MODEL_PATH=./models/xgboost_model_latest.pkl
# SCALER_PATH=./models/scaler_latest.pkl
# Hugging Face: token for gated repos and uploads; repo for download script
# HF_TOKEN=hf_xxxx
# HF_REPO_ID=pejmantheory/bleu-xgboost-classifier

# (Add any other vars your app reads from process.env)
