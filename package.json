{
  "name": "backend",
  "version": "1.2.0",
  "description": "Backend service for Bleu.js",
  "type": "module",
  "main": "index.mjs",
  "scripts": {
    "dev": "sh -c 'test -f .env || cp .env.example .env' && dotenv -e .env -- node server.mjs",
    "start": "node server.mjs",
    "lint": "eslint . --ext .ts,.mjs",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "npm run typecheck && npm run test:smoke && npm run test:api && npm run test:contract && npm run test:unit",
    "test:smoke": "node tests/smoke.mjs",
    "test:api": "node tests/api.mjs",
    "test:contract": "node tests/contract.mjs",
    "test:unit": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/unit.test.mjs",
    "test:unit:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/unit.test.mjs --watch",
    "test:unit:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/unit.test.mjs --coverage",
    "benchmark": "node tests/benchmark.mjs",
    "benchmark:prod": "node tests/benchmark.mjs --url https://api.bleujs.org"
  },
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "^3.1053.0",
    "@aws-sdk/credential-providers": "^3.1063.0",
    "bcrypt": "^6.0.0",
    "compression": "^1.7.4",
    "compromise": "^14.15.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "dotenv-safe": "^9.1.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.3.2",
    "helmet": "^8.2.0",
    "ioredis": "^5.10.1",
    "mongoose": "^9.6.3",
    "morgan": "^1.11.0",
    "natural": "^8.1.1",
    "openai": "^6.42.0",
    "prom-client": "^15.1.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/morgan": "^1.9.9",
    "@types/natural": "^6.0.1",
    "@types/node": "^20.19.0",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^8.57.0",
    "jest": "^30.4.2",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.3",
    "ts-jest": "^29.4.11",
    "tsx": "^4.22.4",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
