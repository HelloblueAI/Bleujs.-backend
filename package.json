{
  "name": "backend",
  "version": "1.2.0",
  "description": "Backend service for Bleu.js",
  "type": "module",
  "main": "index.mjs",
  "scripts": {
    "dev": "dotenv -e .env -- node server.mjs",
    "start": "node server.mjs",
    "lint": "eslint . --ext .ts,.mjs",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "npm run typecheck && npm run test:smoke && npm run test:api && npm run test:contract",
    "test:smoke": "node tests/smoke.mjs",
    "test:api": "node tests/api.mjs",
    "test:contract": "node tests/contract.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "^3.511.0",
    "@aws-sdk/credential-providers": "^3.511.0",
    "bcrypt": "^5.1.1",
    "compression": "^1.7.4",
    "compromise": "^14.15.0",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "dotenv-safe": "^9.1.0",
    "express": "^4.18.3",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.3.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.10.0",
    "mongoose": "^8.2.1",
    "morgan": "^1.10.0",
    "natural": "^6.10.4",
    "openai": "^4.28.0",
    "prom-client": "^15.1.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/morgan": "^1.9.9",
    "@types/natural": "^5.1.5",
    "@types/node": "^20.19.0",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "cross-env": "^7.0.3",
    "dotenv-cli": "^8.0.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "ts-jest": "^29.1.2",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
